# ==========================================================
# TourLens — Master .env.example
# Bitirme Projesi / Fırat Üniversitesi
# ==========================================================
# UYARI: Bu dosya yalnızca şablondur. Gerçek anahtarlar .env
# dosyasına yazılmalı, .env dosyası ASLA Git'e commit edilmemelidir.
# ==========================================================

# ----------------------------------------------------------
# Genel
# ----------------------------------------------------------
APP_ENV=development                  # development | staging | production
APP_DEBUG=true
APP_NAME=TourLens
API_V1_PREFIX=/api/v1
CORS_ORIGINS=*

# ----------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------
POSTGRES_USER=tourlens_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=tourlens
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tourlens_user:change_me_strong_password@postgres:5432/tourlens

# ----------------------------------------------------------
# Redis (cache, broker, rate limit)
# ----------------------------------------------------------
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_DB=1
REDIS_RATE_LIMIT_DB=2

# ----------------------------------------------------------
# Celery
# ----------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_WORKER_CONCURRENCY=4

# ----------------------------------------------------------
# Milvus (vektör DB)
# ----------------------------------------------------------
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=place_embeddings
EMBEDDING_DIM=384

# ----------------------------------------------------------
# MinIO (S3-uyumlu görsel deposu)
# ----------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_secret
MINIO_BUCKET=tourlens-images
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# ----------------------------------------------------------
# JWT / Authentication
# ----------------------------------------------------------
# JWT_SECRET_KEY: minimum 64 karakter rastgele dize.
# Üretim için: openssl rand -hex 64
JWT_SECRET_KEY=change_me_minimum_64_characters_random_string_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth2 (Sign-In)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ----------------------------------------------------------
# Harici API Anahtarları
# ----------------------------------------------------------
GOOGLE_VISION_API_KEY=
GOOGLE_TRANSLATE_API_KEY=
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
YOUTUBE_API_KEY=

# ----------------------------------------------------------
# AI Provider Konfigürasyonu (Strategy Pattern)
# ----------------------------------------------------------
OCR_PROVIDER=google_vision           # google_vision
LLM_CATEGORIZATION_PROVIDER=groq     # groq | gemini
LLM_ENRICHMENT_PROVIDER=gemini       # gemini | groq
LLM_MODERATION_PROVIDER=groq         # groq | gemini (içerik kontrolü; groq önerilir)
TRANSLATION_PROVIDER=google_translate

# Embedding modeli (CPU üzerinde çalışır)
EMBEDDING_MODEL=all-MiniLM-L6-v2
SIMILARITY_THRESHOLD=0.85

# ----------------------------------------------------------
# İçerik moderasyonu (yükleme kontrol mekanizması — § 6.13)
# OCR sonrası: tarihi/turistik tabela DIŞINDAKI görselleri (doğa/hayvan,
# küfür/hakaret, e-posta/kişisel içerik, reklam, alakasız metin) reddeder ve
# DB'ye/Keşfet'e KAYDETMEZ. İki sinyal: LLM metin sınıflandırması + Vision
# SafeSearch/Label (OCR ile aynı çağrı).
# ----------------------------------------------------------
MODERATION_ENABLED=true              # false → eski "her şey kabul" davranışı
MODERATION_MIN_TEXT_CHARS=6          # bu eşikten kısa metin = "okunabilir tabela yok"
MODERATION_SAFE_SEARCH_BLOCK=LIKELY  # VERY_UNLIKELY|UNLIKELY|POSSIBLE|LIKELY|VERY_LIKELY
MODERATION_FAIL_OPEN=true            # LLM kota/hata: true → metin varsa kabul

# LLM modelleri
# NOT: gemini-2.5-flash ÜCRETSIZ katmanda çalışır (önerilen). gemini-2.5-pro
# ve gemini-2.0-flash ücretsiz katmanda çalışmaz; kota biterse provider
# otomatik gemini-flash-latest'e, o da olmazsa Groq'a düşer.
GROQ_MODEL=openai/gpt-oss-120b
GEMINI_CATEGORIZATION_MODEL=gemini-2.5-flash
GEMINI_ENRICHMENT_MODEL=gemini-2.5-flash

# ----------------------------------------------------------
# Rate Limiting (istek/dakika)
# ----------------------------------------------------------
RATE_LIMIT_GENERAL=100
RATE_LIMIT_AUTH=5
RATE_LIMIT_UPLOAD=10
RATE_LIMIT_ENRICH=5

# ----------------------------------------------------------
# Upload limitleri
# ----------------------------------------------------------
MAX_UPLOAD_SIZE_MB=10
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp

# ----------------------------------------------------------
# Cache TTL (saniye)
# ----------------------------------------------------------
TRANSLATION_CACHE_TTL=86400          # 24 saat
YOUTUBE_CACHE_TTL=3600               # 1 saat
ENRICHMENT_CACHE_TTL=604800          # 7 gün

# ----------------------------------------------------------
# Frontend (React Native CLI) — frontend/.env'e kopyalanacak
# ----------------------------------------------------------
# API_BASE_URL=http://10.0.2.2:8000/api/v1   # Android emülatör için
# GOOGLE_MAPS_API_KEY_ANDROID=
# GOOGLE_OAUTH_WEB_CLIENT_ID=
