<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-feature android:name="android.hardware.camera" android:required="true" />

    <!--
        Android 11+ (API 30) paket görünürlük kuralı: Linking.canOpenURL ve
        Intent çözümlemesinin başka bir uygulamayı bulabilmesi için bu
        <queries> bloğu gerekir. YouTube deeplink'leri ve genel http(s)
        açma davranışı bu sayede çalışır.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="http" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="vnd.youtube" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="geo" />
        </intent>
        <intent>
            <action android:name="android.intent.action.DIAL" />
        </intent>
        <!--
            Cihazdaki TTS (Text-to-Speech) motoru ayrı bir uygulama servisidir.
            Android 11+ paket görünürlüğü altında react-native-tts'in motoru
            bulup bağlanabilmesi (getInitStatus + speak) için bu intent ŞART.
            Yoksa init sessizce başarısız olur ve hiç ses çıkmaz.
        -->
        <intent>
            <action android:name="android.intent.action.TTS_SERVICE" />
        </intent>
        <package android:name="com.google.android.youtube" />
    </queries>

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme"
        android:supportsRtl="true">

        <!--
            API key SADECE .env'deki GOOGLE_MAPS_API_KEY üzerinden okunur
            (react-native-config dotenv.gradle resValue ile string kaynağına
            yazıyor). Hardcoded tutmuyoruz ki .env güncellendiğinde manifest
            otomatik yansıtsın.

            UYARI — boş ekran (sadece "Google" logosu) yaşıyorsanız sorun
            HER ZAMAN Google Cloud Console tarafındadır:
              1) "Maps SDK for Android" API'si etkin mi?
              2) Billing (faturalandırma) projede etkin mi?
              3) API key'de paket-adı kısıtlaması varsa "com.jourex" +
                 doğru SHA-1 fingerprint eklenmiş mi?
              4) API key'de "Maps SDK for Android" ürünü seçili mi?
            Bu üçünden biri eksikse harita render edilmez.
        -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/GOOGLE_MAPS_API_KEY_ANDROID" />

        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
